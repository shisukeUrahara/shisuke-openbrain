# .env.example — copy to .env and fill values. NEVER commit .env.
#
# Resolution order: env vars override config/features.yaml.
# See plan/PLANNED_PHASES.md Section A.4 for the module toggle mechanism.

# ───────────────────────── CORE ─────────────────────────
# Postgres connection. Local dev uses docker-compose service hostname.
DATABASE_URL=postgresql://postgres:devpass@localhost:5432/openbrain

# 64-char hex from `openssl rand -hex 32`. Required.
BRAIN_KEY=

# Postgres credentials used by docker-compose to bootstrap the dev DB.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=devpass
POSTGRES_DB=openbrain

# ─────────────────────── EMBEDDING ──────────────────────
# openrouter | ollama
EMBED_PROVIDER=openrouter
OPENROUTER_API_KEY=
# Used only when EMBED_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434

# ───────────────────── MODULE TOGGLES ────────────────────
# All default false. Flip to true to enable a module after its phase ships.
MODULE_DOCUMENTS_ENABLED=false
MODULE_TELEGRAM_BOT_ENABLED=false
MODULE_WORKERS_ARTICLE_ENABLED=false
MODULE_WORKERS_PDF_ENABLED=false
MODULE_WORKERS_AUDIO_ENABLED=false
MODULE_WORKERS_IMAGE_ENABLED=false
MODULE_OBSIDIAN_MIRROR_ENABLED=false
MODULE_N8N_SCHEDULER_ENABLED=false
MODULE_GRAPHIFY_ENABLED=false

# ─────────────────── MODULE-SPECIFIC ENV ─────────────────
# Only used when the respective module is enabled.

# Telegram bot (phase 11)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
BRAIN_URL=

# Redis (phase 12.a — workers queue)
REDIS_URL=redis://redis:6379/0
